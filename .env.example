# Wix CMS sync — used by scripts/sync-from-wix.mjs.
# Copy this file to .env (which is gitignored) and fill in real values.
#
# Generate / find these in the Wix dashboard:
#   WIX_SITE_ID         Settings > API Keys (top of page)
#   WIX_API_KEY         Settings > API Keys > Generate (Wix Data: Read items)
#   WIX_COLLECTION_ID   Content Manager > Neighborhoods & Condos
#                       > More Actions > Get Collection ID
#
# These never get committed; the sync script reads them via process.env.

WIX_SITE_ID=
WIX_API_KEY=
WIX_COLLECTION_ID=
